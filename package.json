{
  "name": "@antelopejs/interface-stripe",
  "version": "0.0.2",
  "description": "AntelopeJS interface for Stripe payment integration",
  "keywords": [
    "antelopejs",
    "interface",
    "stripe",
    "payment"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AntelopeJS/interface-stripe.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.6.5",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "biome format --write .",
    "lint:fix": "biome check --write .",
    "lint": "biome check .",
    "prepack": "pnpm run build",
    "release": "pnpm run lint && pnpm run prepack && release-it"
  },
  "dependencies": {
    "@antelopejs/interface-core": "^0.0.2",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/node": "^22.19.15",
    "release-it": "^19.2.4",
    "release-it-changelogen": "^0.1.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
